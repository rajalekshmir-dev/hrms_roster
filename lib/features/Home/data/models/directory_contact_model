import '../../domain/entities/directory_contact.dart';

class DirectoryContactModel extends DirectoryContact {
  const DirectoryContactModel({
    required super.name,
    required super.title,
    required super.location,
    super.email,
    super.phone,
    super.avatar,
    super.id,
    super.department,
    super.occupancyPercent,
  });

  factory DirectoryContactModel.fromJson(Map<String, dynamic> json) {
    final name = json['name'] ??
        json['display_name'] ??
        json['full_name'] ??
        json['employee_name'] ??
        '';

    final title = json['title'] ??
        json['designation'] ??
        json['position'] ??
        json['role'] ??
        '';

    final location = json['location'] ??
        json['office_location'] ??
        json['branch'] ??
        json['city'] ??
        '';

    return DirectoryContactModel(
      name: name,
      title: title,
      location: location,
      email: json['email'] ?? json['work_email'],
      phone: json['phone'] ?? json['mobile'],
      avatar: json['avatar'] ?? json['profile_pic'],
      id: json['id'] ?? json['employee_id'],
      department: json['department'] ?? json['dept'],
      occupancyPercent: json['occupancy_percent'] ?? 0,
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'name': name,
      'title': title,
      'location': location,
      'email': email,
      'phone': phone,
      'avatar': avatar,
      'id': id,
      'department': department,
      'occupancy_percent': occupancyPercent,
    };
  }
}